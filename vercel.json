@'
{
  "version": 2,
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@3.2.0",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/generar-seo",
      "methods": ["POST"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Headers": "Content-Type, X-Proxy-Secret"
      }
    }
  ]
}
'@ | Out-File -FilePath "vercel.json" -Encoding utf8